# Database
DB_HOST=postgres
DB_NAME=expense_tracker
DB_USER=expense_user
DB_PASSWORD=change-me-strong-password

# Auth
SECRET_KEY=change-me-to-at-least-32-random-characters

# App
ALLOW_REGISTRATION=true
CORS_ORIGINS=https://yourdomain.com,http://localhost:5173

# Upload directory (inside container)
UPLOAD_DIR=/app/data/uploads

# AI providers — provide at least one key for OCR and AI chat
GROQ_API_KEY=gsk_your_key_here
OPENROUTER_API_KEY=sk-or-your_key_here
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Stripe — create products/prices in Stripe dashboard, then paste IDs here
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_SOLO=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...
STRIPE_PRICE_OVERAGE=price_...

# Domain (used by Stripe checkout success/cancel URLs)
APP_DOMAIN=https://yourdomain.com
