# Backend
GROQ_API_KEY=gsk_your_key_here
OPENROUTER_API_KEY=sk-or-your_key_here
DATABASE_URL=sqlite:////app/data/expense_tracker.db
UPLOAD_DIR=/app/data/uploads
SECRET_KEY=change-me-to-32-random-chars-minimum
ALLOW_REGISTRATION=true
OCR_CONFIDENCE_THRESHOLD=0.75
AI_MAX_RETRIES=2
CORS_ORIGINS=["https://yourdomain.com","http://localhost:3000"]

# Stripe — only fill these 3, then run:  python stripe_setup.py
# The script auto-creates products, prices, and webhook and writes the rest.
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
APP_DOMAIN=https://yourdomain.com
# (stripe_setup.py writes these automatically — do not edit manually)
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SOLO=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_OVERAGE=

# Frontend
NEXT_PUBLIC_API_URL=https://yourdomain.com/api/v1
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
