# Replace yourdomain.com with your actual domain
yourdomain.com {
    # API → backend
    handle /api/* {
        reverse_proxy backend:8000
    }

    # Everything else → Next.js frontend
    handle {
        reverse_proxy frontend:3000
    }
}

# For local testing without a domain:
# :80 {
#     handle /api/* {
#         reverse_proxy backend:8000
#     }
#     handle {
#         reverse_proxy frontend:3000
#     }
# }
